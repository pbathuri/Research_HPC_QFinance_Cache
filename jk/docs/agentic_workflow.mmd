graph TD
    Start([Pipeline Start]) --> Env[EnvironmentAgent<br/>EnvBot]
    Env --> Data[DataIngestionAgent<br/>DataBot]
    Env --> Cache[CacheResearchAgent<br/>CacheBot]
    Env --> Lit[LiteratureReviewAgent<br/>LitBot]
    Data --> Viz[VisualizationAgent<br/>VizBot]
    Data --> Report[ReportAgent<br/>ReportBot]
    Cache --> Report
    Lit --> Report
    Viz --> Report
    Report --> Pixel[Pixel Trace Export]
    Report --> Metrics[CSV Metrics Flush]
    Pixel --> End([Pipeline End])
    Metrics --> End

    style Env fill:#2E86AB,color:white
    style Data fill:#A23B72,color:white
    style Cache fill:#F18F01,color:white
    style Lit fill:#C73E1D,color:white
    style Viz fill:#44BBA4,color:white
    style Report fill:#E94F37,color:white
    style Pixel fill:#6A0572,color:white
    style Metrics fill:#1B998B,color:white
