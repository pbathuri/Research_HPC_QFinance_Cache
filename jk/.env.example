# ── qhpc_cache research platform: environment variables ──────────────
# Copy to .env and fill in values.  The system degrades gracefully for
# any missing variable; see scripts/check_env.py for a runtime report.

# ── Data sources ─────────────────────────────────────────────────────
DATABENTO_API_KEY=
QHPC_DATA_ROOT=data/qhpc_data

# ── kdb / TAQ ────────────────────────────────────────────────────────
QHPC_KDB_TAQ_REPO=/Users/prady/Desktop/kdb-taq
QHPC_KDB_Q_BINARY=q
QHPC_KDB_EXTRACTION_COMMAND=

# ── Pipeline budgets ─────────────────────────────────────────────────
QHPC_PIPELINE_TIME_BUDGET_SEC=6480
QHPC_PIPELINE_DISK_BUDGET_BYTES=48318382080

# ── Databento tuning ─────────────────────────────────────────────────
QHPC_DATABENTO_DAILY_DATASET=EQUS.MINI
QHPC_DATABENTO_SCHEMA=ohlcv-1d

# ── WRDS / CRSP (future) ────────────────────────────────────────────
WRDS_USERNAME=
WRDS_PASSWORD=

# ── Literature / arXiv (optional) ───────────────────────────────────
QHPC_ARXIV_SEARCH_ENABLED=true
QHPC_LOCAL_PAPERS_DIR=data/papers
QHPC_LANGCHAIN_LOCAL_PATH=/Users/prady/Desktop/langchain

# ── Output paths ─────────────────────────────────────────────────────
QHPC_OUTPUT_ROOT=outputs
QHPC_METRICS_DIR=outputs/metrics
QHPC_FIGURES_DIR=outputs/figures
QHPC_REPORTS_DIR=outputs/reports
